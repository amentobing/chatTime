{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,

    /* PENGATURAN DIREKTORI (Sangat Krusial untuk Docker) */
    "outDir": "./dist",
    "rootDir": "./src"
  },
  "include": ["src/**/*"]
}
